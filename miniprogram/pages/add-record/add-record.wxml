<view class="page-container">
  <view class="type-toggle card p-15">
    <view class="toggle-item expense {{recordType === 'expense' ? 'active' : ''}}" bindtap="switchType" data-type="expense">
      支出
    </view>
    <view class="toggle-divider"></view>
    <view class="toggle-item income {{recordType === 'income' ? 'active' : ''}}" bindtap="switchType" data-type="income">
      收入
    </view>
  </view>

  <view class="amount-card card p-20 mt-20">
    <view class="amount-label">金额</view>
    <view class="amount-input-wrapper">
      <text class="amount-symbol {{recordType}}">¥</text>
      <input 
        class="amount-input" 
        type="text" 
        placeholder="0.00" 
        value="{{amount}}"
        bindinput="onAmountInput"
        bindblur="onAmountBlur"
        focus="{{true}}"
      />
    </view>
  </view>

  <view class="category-section mt-20">
    <view class="section-title">选择类别</view>
    
    <!-- 大类选择 -->
    <view class="category-step" wx:if="{{!selectedGroupId}}">
      <view class="category-group-list">
        <view 
          wx:for="{{categoryData.groups}}" 
          wx:key="id" 
          class="category-group-option"
          bindtap="selectGroup"
          data-group="{{item}}"
        >
          <view class="group-option-icon badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
            <text class="badge-glyph">{{item.badge.symbol}}</text>
            <text class="badge-mark-text">{{item.badge.label}}</text>
          </view>
          <view class="group-option-text">{{item.name}}</view>
          <view class="group-option-arrow">›</view>
        </view>
      </view>
    </view>
    
    <!-- 小类选择 -->
    <view class="category-step" wx:else>
      <view class="category-step-header">
        <view class="back-btn" bindtap="backToGroups">‹ 返回</view>
        <view class="step-title">{{selectedGroup.name}}</view>
      </view>
      <view class="category-grid">
        <view 
          wx:for="{{selectedGroup.children}}" 
          wx:key="id" 
          class="category-item {{recordType}} {{selectedCategoryId === item.id ? 'selected' : ''}}"
          bindtap="selectCategory"
          data-id="{{item.id}}"
          data-cat="{{item}}"
        >
          <view class="category-icon-wrapper badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
            <text class="badge-glyph">{{item.badge.symbol}}</text>
            <text class="badge-mark-text">{{item.badge.label}}</text>
          </view>
          <view class="category-name">{{item.name}}</view>
        </view>
      </view>
    </view>
    
    <!-- 已选类别显示 -->
    <view class="selected-category" wx:if="{{selectedCategoryDisplay}}">
      <view class="selected-label">已选择：</view>
      <view class="selected-display">
        <view class="selected-icon badge-mark {{selectedCategoryDisplay.badge.className}}" style="background: {{selectedCategoryDisplay.badge.background}}; border-color: {{selectedCategoryDisplay.badge.color}}; color: {{selectedCategoryDisplay.badge.color}};">
          <text class="badge-glyph">{{selectedCategoryDisplay.badge.symbol}}</text>
          <text class="badge-mark-text">{{selectedCategoryDisplay.badge.label}}</text>
        </view>
        <text class="selected-text {{recordType}}">{{selectedCategoryDisplay.groupName}} - {{selectedCategoryDisplay.name}}</text>
      </view>
    </view>
  </view>

  <view class="account-section mt-20">
    <view class="section-title">选择账户</view>
    <view class="account-selector card p-15" bindtap="showAccountPicker">
      <view class="account-display" wx:if="{{selectedAccountId}}">
        <view wx:for="{{accounts}}" wx:key="id" wx:if="{{item.id === selectedAccountId}}">
          <view class="account-icon badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
            <text class="badge-glyph">{{item.badge.symbol}}</text>
            <text class="badge-mark-text">{{item.badge.label}}</text>
          </view>
          <text class="account-name-text">{{item.displayName}}</text>
          <text class="account-balance">¥{{item.balance}}</text>
        </view>
      </view>
      <view class="account-placeholder" wx:else>
        <text class="placeholder-text">请选择账户</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="date-card card p-20 mt-20">
    <view class="date-label">日期</view>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-value">{{dateText}}</view>
    </picker>
  </view>

  <view class="note-card card p-20 mt-20">
    <view class="note-label">备注</view>
    <textarea 
      class="note-input" 
      placeholder="添加备注（选填）"
      value="{{note}}"
      bindinput="onNoteInput"
      maxlength="100"
    ></textarea>
    <view class="note-count">{{note.length}}/100</view>
  </view>

  <view class="btn-group mt-40">
    <button class="save-btn btn-primary" bindtap="saveRecord" disabled="{{isSaving}}">
      {{isEdit ? '更新记录' : '保存记录'}}
    </button>
  </view>

  <!-- 账户选择弹窗 -->
  <view class="account-picker-mask {{showAccountPicker ? 'show' : ''}}" bindtap="hideAccountPicker">
    <view class="account-picker-popup" catchtap="onPopupTap">
      <view class="popup-header">
        <text class="popup-title">选择账户</text>
        <text class="popup-close" bindtap="hideAccountPicker">×</text>
      </view>
      
      <!-- 账户分类选择 -->
      <view class="account-category-step" wx:if="{{!selectedAccountCategoryId}}">
        <scroll-view scroll-y class="account-list">
          <view 
            wx:for="{{groupedAccounts}}" 
            wx:key="id" 
            class="account-category-option"
            bindtap="selectAccountCategory"
            data-category="{{item}}"
          >
            <view class="category-option-icon badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
              <text class="badge-glyph">{{item.badge.symbol}}</text>
              <text class="badge-mark-text">{{item.badge.label}}</text>
            </view>
            <view class="category-option-info">
              <text class="category-option-name">{{item.name}}</text>
              <text class="category-option-count">{{item.children.length}} 个账户</text>
            </view>
            <view class="category-option-arrow">›</view>
          </view>
        </scroll-view>
      </view>
      
      <!-- 具体账户选择 -->
      <view class="account-step" wx:else>
        <view class="account-step-header">
          <view class="back-btn" bindtap="backToAccountCategories">‹ 返回</view>
          <view class="step-title">{{selectedAccountCategory.name}}</view>
        </view>
        <scroll-view scroll-y class="account-list">
          <view 
            wx:for="{{selectedAccountCategory.children}}" 
            wx:key="id" 
            class="account-option {{recordType}} {{selectedAccountId === item.id ? 'selected' : ''}}"
            bindtap="selectAccount"
            data-id="{{item.id}}"
          >
            <view class="account-icon badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
              <text class="badge-glyph">{{item.badge.symbol}}</text>
              <text class="badge-mark-text">{{item.badge.label}}</text>
            </view>
            <view class="account-info">
              <text class="account-name-text">{{item.displayName}}</text>
              <text class="account-category">{{item.category}}</text>
            </view>
            <text class="account-balance">¥{{item.balance}}</text>
            <view class="check-icon {{recordType}}" wx:if="{{selectedAccountId === item.id}}">✓</view>
          </view>
        </scroll-view>
      </view>
      
      <view class="no-account" wx:if="{{accounts.length === 0}}">
        <text>暂无账户，请先添加账户</text>
      </view>
    </view>
  </view>
</view>
