.page-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.form-card {
  margin-bottom: 30rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
}

.icon-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FDF8F3;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.icon-item.selected {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.icon-emoji {
  font-size: 48rpx;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
}

.amount-symbol {
  font-size: 40rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin-right: 10rpx;
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.note-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.delete-btn {
  background: #FFF5F5;
  color: #FF6B6B;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.save-btn {
  width: 100%;
  padding: 30rpx 0;
  font-size: 34rpx;
  border: none;
  border-radius: 24rpx;
}

/* Dark fintech account edit overrides */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 80rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(34, 211, 238, 0.12), transparent 34%),
    linear-gradient(180deg, #07101D 0%, #070B14 100%);
}

.form-card {
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: none;
}

.form-title {
  color: #E5EEF8;
}

.form-label,
.note-count {
  color: #8EA0B8;
}

.form-input,
.picker-value,
.amount-input-wrapper,
.form-textarea {
  background: rgba(2, 6, 23, 0.26);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  color: #E5EEF8;
}

.amount-symbol {
  color: #67E8F9;
}

.amount-input {
  color: #E5EEF8;
}

.icon-item {
  background: rgba(15, 23, 42, 0.78);
  border-color: rgba(148, 163, 184, 0.12);
}

.icon-item.selected {
  border-color: #22D3EE;
  background: rgba(34, 211, 238, 0.10);
}

.delete-btn {
  color: #F87171;
  background: rgba(248, 113, 113, 0.10);
  border: 1rpx solid rgba(248, 113, 113, 0.20);
}
