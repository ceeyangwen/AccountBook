.page-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.form-card {
  margin-bottom: 30rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
}

.icon-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FDF8F3;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.icon-item.selected {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.icon-emoji {
  font-size: 48rpx;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
}

.amount-symbol {
  font-size: 40rpx;
  color: #FF6B6B;
  font-weight: 700;
  margin-right: 10rpx;
}

.amount-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.form-textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 24rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.note-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.delete-btn {
  background: #FFF5F5;
  color: #FF6B6B;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.save-btn {
  width: 100%;
  padding: 30rpx 0;
  font-size: 34rpx;
  border: none;
  border-radius: 24rpx;
}