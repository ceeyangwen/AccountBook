.page-container {
  padding: 20rpx;
}

.amount-card {
  text-align: center;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.amount-symbol {
  font-size: 48rpx;
  color: #4ECDC4;
  font-weight: 700;
  margin-right: 10rpx;
}

.amount-input {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  min-width: 200rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.account-section {
  margin-top: 30rpx;
}

.account-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  border-radius: 16rpx;
}

.account-display {
  display: flex;
  align-items: center;
  flex: 1;
}

.account-display > view {
  display: flex;
  align-items: center;
  width: 100%;
}

.account-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.account-name-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.account-balance {
  font-size: 28rpx;
  color: #4ECDC4;
  font-weight: 600;
}

.account-placeholder {
  flex: 1;
}

.placeholder-text {
  font-size: 30rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 10rpx;
}

.transfer-arrow {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.arrow-icon {
  font-size: 48rpx;
  color: #4ECDC4;
  font-weight: bold;
}

.date-card, .note-card {
  display: flex;
  flex-direction: column;
}

.date-label, .note-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.date-value {
  font-size: 32rpx;
  color: #333;
  padding: 16rpx 0;
}

.note-input {
  min-height: 120rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  padding: 16rpx;
  background: #FDF8F3;
  border-radius: 12rpx;
}

.note-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.btn-group {
  padding: 20rpx 0;
}

.save-btn {
  width: 100%;
  padding: 30rpx 0;
  font-size: 34rpx;
  border: none;
  border-radius: 30rpx;
}

/* 账户选择弹窗 */
.account-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.account-picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.account-picker-popup {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.account-picker-mask.show .account-picker-popup {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #EEE;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.account-list {
  max-height: 60vh;
  padding: 20rpx;
}

.account-category-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #F9F9F9;
}

.category-option-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E8F8F5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.category-option-emoji {
  font-size: 36rpx;
}

.category-option-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.category-option-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.category-option-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.category-option-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 16rpx;
}

.account-step-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 10rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.back-btn {
  font-size: 28rpx;
  color: #4ECDC4;
  min-width: 120rpx;
}

.step-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding-right: 120rpx;
}

.account-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: #F9F9F9;
  transition: all 0.3s;
}

.account-option.selected {
  background: #E8F8F5;
  border: 2rpx solid #4ECDC4;
}

.account-option.disabled {
  opacity: 0.5;
}

.account-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 16rpx;
}

.account-category {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  background: #4ECDC4;
  border-radius: 50%;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.no-account {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
