<view class="page-container">
  <view class="amount-card card p-20">
    <view class="amount-label">转账金额</view>
    <view class="amount-input-wrapper">
      <text class="amount-symbol">¥</text>
      <input 
        class="amount-input" 
        type="digit" 
        placeholder="0.00" 
        value="{{amount}}"
        bindinput="onAmountInput"
        focus="{{true}}"
      />
    </view>
  </view>

  <view class="account-section mt-20">
    <view class="section-title">📤 转出账户</view>
    <view class="account-selector card p-15" bindtap="showFromPicker">
      <view class="account-display" wx:if="{{fromAccountId}}">
        <view wx:for="{{accounts}}" wx:key="id" wx:if="{{item.id === fromAccountId}}">
          <text class="account-icon">{{item.icon}}</text>
          <text class="account-name-text">{{item.name}}</text>
          <text class="account-balance">¥{{item.balance}}</text>
        </view>
      </view>
      <view class="account-placeholder" wx:else>
        <text class="placeholder-text">请选择转出账户</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="transfer-arrow">
    <text class="arrow-icon">↓</text>
  </view>

  <view class="account-section">
    <view class="section-title">📥 转入账户</view>
    <view class="account-selector card p-15" bindtap="showToPicker">
      <view class="account-display" wx:if="{{toAccountId}}">
        <view wx:for="{{accounts}}" wx:key="id" wx:if="{{item.id === toAccountId}}">
          <text class="account-icon">{{item.icon}}</text>
          <text class="account-name-text">{{item.name}}</text>
          <text class="account-balance">¥{{item.balance}}</text>
        </view>
      </view>
      <view class="account-placeholder" wx:else>
        <text class="placeholder-text">请选择转入账户</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="date-card card p-20 mt-20">
    <view class="date-label">📅 日期</view>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-value">{{dateText}}</view>
    </picker>
  </view>

  <view class="note-card card p-20 mt-20">
    <view class="note-label">✏️ 备注</view>
    <textarea 
      class="note-input" 
      placeholder="添加备注（选填）"
      value="{{note}}"
      bindinput="onNoteInput"
      maxlength="100"
    ></textarea>
    <view class="note-count">{{note.length}}/100</view>
  </view>

  <view class="btn-group mt-40">
    <button class="save-btn btn-primary" bindtap="saveTransfer">
      {{isEdit ? '✏️ 更新转账' : '💾 确认转账'}}
    </button>
  </view>

  <!-- 转出账户选择弹窗 -->
  <view class="account-picker-mask {{showFromPicker ? 'show' : ''}}" bindtap="hideFromPicker">
    <view class="account-picker-popup" catchtap="">
      <view class="popup-header">
        <text class="popup-title">选择转出账户</text>
        <text class="popup-close" bindtap="hideFromPicker">×</text>
      </view>
      <scroll-view scroll-y class="account-list">
        <view 
          wx:for="{{accounts}}" 
          wx:key="id" 
          class="account-option {{fromAccountId === item.id ? 'selected' : ''}} {{item.id === toAccountId ? 'disabled' : ''}}"
          bindtap="selectFromAccount"
          data-id="{{item.id}}"
        >
          <text class="account-icon">{{item.icon}}</text>
          <view class="account-info">
            <text class="account-name-text">{{item.name}}</text>
            <text class="account-category">{{item.category}}</text>
          </view>
          <text class="account-balance">¥{{item.balance}}</text>
          <view class="check-icon" wx:if="{{fromAccountId === item.id}}">✓</view>
        </view>
      </scroll-view>
      <view class="no-account" wx:if="{{accounts.length === 0}}">
        <text>暂无账户，请先添加账户</text>
      </view>
    </view>
  </view>

  <!-- 转入账户选择弹窗 -->
  <view class="account-picker-mask {{showToPicker ? 'show' : ''}}" bindtap="hideToPicker">
    <view class="account-picker-popup" catchtap="">
      <view class="popup-header">
        <text class="popup-title">选择转入账户</text>
        <text class="popup-close" bindtap="hideToPicker">×</text>
      </view>
      <scroll-view scroll-y class="account-list">
        <view 
          wx:for="{{accounts}}" 
          wx:key="id" 
          class="account-option {{toAccountId === item.id ? 'selected' : ''}} {{item.id === fromAccountId ? 'disabled' : ''}}"
          bindtap="selectToAccount"
          data-id="{{item.id}}"
        >
          <text class="account-icon">{{item.icon}}</text>
          <view class="account-info">
            <text class="account-name-text">{{item.name}}</text>
            <text class="account-category">{{item.category}}</text>
          </view>
          <text class="account-balance">¥{{item.balance}}</text>
          <view class="check-icon" wx:if="{{toAccountId === item.id}}">✓</view>
        </view>
      </scroll-view>
      <view class="no-account" wx:if="{{accounts.length === 0}}">
        <text>暂无账户，请先添加账户</text>
      </view>
    </view>
  </view>
</view>
