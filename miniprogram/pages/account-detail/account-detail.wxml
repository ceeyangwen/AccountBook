<view class="page-container">
  <view class="account-header card p-20">
    <view class="account-info">
      <view class="account-icon-wrapper badge-mark {{account.badge.className}}" style="background: {{account.badge.background}}; border-color: {{account.badge.color}}; color: {{account.badge.color}};">
        <text class="badge-glyph">{{account.badge.symbol}}</text>
        <text class="badge-mark-text">{{account.badge.label}}</text>
      </view>
      <view class="account-details">
        <view class="account-name">{{account.name}}</view>
        <view class="account-category">{{account.category}}</view>
      </view>
    </view>
    <view class="account-balance {{accountType === 'debt' || accountType === 'credit' ? 'debt' : ''}}">
      <view class="balance-label">{{balanceLabel}}</view>
      <view class="balance-value">¥{{account.balance}}</view>
    </view>
  </view>

  <view class="quick-action-section card p-20 mt-20">
    <view class="quick-action-title">快捷操作</view>
    <view class="quick-action-list">
      <view class="quick-action-button record" bindtap="goToQuickRecord">
        <text class="quick-action-icon">＋</text>
        <text class="quick-action-text">记一笔</text>
      </view>
      <view class="quick-action-button transfer" bindtap="goToQuickTransfer">
        <text class="quick-action-icon">↔</text>
        <text class="quick-action-text">转账</text>
      </view>
    </view>
  </view>

  <view class="summary-section mt-20">
    <view class="summary-title">操作统计</view>
    <view class="summary-grid">
      <view class="summary-item">
        <view class="summary-label">支出</view>
        <view class="summary-value expense">-¥{{summary.totalExpense}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">收入</view>
        <view class="summary-value income">+¥{{summary.totalIncome}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">转出</view>
        <view class="summary-value transfer">-¥{{summary.totalTransferOut}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">转入</view>
        <view class="summary-value transfer-in">+¥{{summary.totalTransferIn}}</view>
      </view>
    </view>
  </view>

  <view class="record-section mt-20">
    <view class="section-title">操作记录</view>
    
    <view wx:if="{{groupedRecords.length === 0}}" class="empty-state">
      <view class="empty-icon">REC</view>
      <view class="empty-text">暂无操作记录</view>
    </view>

    <view wx:for="{{groupedRecords}}" wx:key="date" class="date-group">
      <view class="date-header">
        <view class="date-text">{{item.dateText}}</view>
      </view>
      
      <view wx:for="{{item.records}}" wx:for-item="record" wx:key="id" class="record-card card" bindtap="goToEditRecord" data-record="{{record}}">
        <view class="record-left">
          <view class="record-icon badge-mark {{record.recordType}} {{record.recordBadge.className}}" style="background: {{record.recordBadge.background}}; border-color: {{record.recordBadge.color}}; color: {{record.recordBadge.color}};">
            <image wx:if="{{record.recordBadge.iconImage}}" class="badge-image" src="{{record.recordBadge.iconImage}}" mode="aspectFit"></image>
            <block wx:else>
              <text class="badge-glyph">{{record.recordBadge.symbol}}</text>
              <text class="badge-mark-text">{{record.recordBadge.label}}</text>
            </block>
          </view>
          <view class="record-info">
            <view class="record-type">
              <block wx:if="{{record.type === 'transfer'}}">
                <block wx:if="{{record.fromAccountId === account.id}}">转出至 {{record.toAccountName}}</block>
                <block wx:else>从 {{record.fromAccountName}} 转入</block>
              </block>
              <block wx:else>{{record.categoryName}}</block>
            </view>
            <view class="record-note" wx:if="{{record.note}}">{{record.note}}</view>
          </view>
        </view>
        <view class="record-right">
          <view class="record-amount {{record.recordType}}">
            <block wx:if="{{record.type === 'transfer'}}">
              <block wx:if="{{record.fromAccountId === account.id}}">-¥{{record.amount}}</block>
              <block wx:else>+¥{{record.amount}}</block>
            </block>
            <block wx:else>
              {{record.type === 'expense' ? '-' : '+'}}¥{{record.amount}}
            </block>
          </view>
          <view class="record-actions">
            <text class="action-text" catchtap="deleteRecord" data-record="{{record}}">删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
