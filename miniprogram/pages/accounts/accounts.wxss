.page-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.summary-card {
  margin-bottom: 30rpx;
  text-align: center;
}

.summary-header {
  align-items: center;
}

.summary-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.edit-btn {
  font-size: 28rpx;
  color: #FF6B6B;
  padding: 8rpx 20rpx;
  border: 2rpx solid #FF6B6B;
  border-radius: 8rpx;
}

.total-amount {
  font-size: 56rpx;
  font-weight: 700;
}

.account-list {
  margin-bottom: 30rpx;
}

.category-group {
  margin-bottom: 30rpx;
}

.category-header {
  padding: 10rpx 10rpx 20rpx;
  align-items: center;
}

.category-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.category-collapse-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
  color: #8EA0B8;
  font-size: 34rpx;
  line-height: 1;
  flex-shrink: 0;
}

.category-icon {
  margin-right: 10rpx;
}

.category-total {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.account-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  transition: transform 0.2s ease;
}

.account-item.editing {
  padding-left: 0;
}

.drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  padding: 24rpx 0;
}

.drag-icon {
  font-size: 40rpx;
  color: #CCC;
  font-weight: bold;
}

.account-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
}

.drag-actions {
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
}

.drag-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FF6B6B;
  background: #FFF5F5;
  border-radius: 8rpx;
  margin: 4rpx 0;
}

.drag-btn.disabled {
  color: #CCC;
  background: #F5F5F5;
}

.drag-btn.up {
  margin-bottom: 4rpx;
}

.drag-btn.down {
  margin-top: 4rpx;
}

.account-left {
  flex: 1;
  min-width: 0;
}

.account-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.account-icon {
  font-size: 40rpx;
}

.account-info {
  flex: 1;
  min-width: 0;
}

.account-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  margin-bottom: 6rpx;
}

.account-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exclude-total-label {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #9A6B00;
  background: #FFF8E6;
  border: 1rpx solid #F0DDA0;
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.hidden-account-label {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #6B5B95;
  background: #F2EFFF;
  border: 1rpx solid #D8CFFF;
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.account-note {
  font-size: 24rpx;
  color: #999;
}

.account-right {
  width: 200rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  text-align: right;
}

.account-balance {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.account-balance.debt {
  color: #FF6B6B;
}

.account-actions {
  display: flex;
  justify-content: flex-end;
  width: 100%;
  gap: 12rpx;
}

.action-btn {
  min-width: 56rpx;
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #F5F5F5;
  text-align: center;
}

.action-btn.delete {
  color: #FF6B6B;
  background: #FFF5F5;
}

.add-quick-account {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  color: #FF6B6B;
  font-size: 26rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.add-quick-account .add-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.floating-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  z-index: 100;
}

.floating-icon {
  font-size: 60rpx;
  color: white;
  font-weight: 300;
  line-height: 1;
}

.quick-add-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 200;
}

.quick-add-content {
  background: white;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.quick-add-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.quick-account-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.quick-account-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #FDF8F3;
  border-radius: 16rpx;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.quick-name {
  font-size: 26rpx;
  color: #333;
  text-align: center;
}

.cancel-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #999;
  background: #F5F5F5;
  border-radius: 24rpx;
}

/* Dark fintech dashboard overrides */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at 16% 0%, rgba(34, 211, 238, 0.12), transparent 34%),
    linear-gradient(180deg, #07101D 0%, #070B14 100%);
}

.summary-card {
  background: linear-gradient(135deg, rgba(17, 28, 46, 0.98), rgba(10, 20, 36, 0.96));
}

.summary-title,
.category-name,
.account-name,
.quick-add-title {
  color: #E5EEF8;
}

.total-amount {
  color: #67E8F9;
  text-shadow: 0 0 22rpx rgba(34, 211, 238, 0.26);
}

.debug-info {
  background: rgba(15, 23, 42, 0.68) !important;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  color: #8EA0B8 !important;
}

.category-header {
  color: #E5EEF8;
}

.category-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
}

.category-icon .badge-glyph {
  top: 11rpx;
  font-size: 24rpx;
}

.category-icon .badge-mark-text {
  right: 4rpx;
  bottom: 3rpx;
  min-width: 20rpx;
  height: 18rpx;
  font-size: 13rpx;
}

.category-total,
.account-note {
  color: #8EA0B8;
}

.account-item {
  background: rgba(15, 23, 42, 0.78);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: none;
}

.account-icon-wrapper {
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 18rpx;
  box-shadow: inset 0 0 20rpx rgba(255, 255, 255, 0.04);
}

.account-icon {
  font-size: 30rpx;
  font-weight: 800;
}

.account-balance {
  color: #E5EEF8;
}

.account-balance.debt {
  color: #EF4444;
}

.exclude-total-label {
  color: #FACC15;
  background: rgba(250, 204, 21, 0.12);
  border-color: rgba(250, 204, 21, 0.26);
}

.hidden-account-label {
  color: #67E8F9;
  background: rgba(34, 211, 238, 0.12);
  border-color: rgba(34, 211, 238, 0.24);
}

.action-btn {
  color: #67E8F9;
  background: rgba(34, 211, 238, 0.10);
}

.action-btn.delete {
  color: #F87171;
  background: rgba(248, 113, 113, 0.10);
}

.drag-icon {
  color: #64748B;
}

.drag-btn {
  color: #67E8F9;
  background: rgba(34, 211, 238, 0.10);
}

.drag-btn.disabled {
  color: #475569;
  background: rgba(71, 85, 105, 0.20);
}

.add-quick-account {
  color: #67E8F9;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx dashed rgba(34, 211, 238, 0.28);
}

.empty-tip-text {
  color: #CBD5E1;
}

.empty-tip-subtext {
  color: #8EA0B8;
}

.floating-btn {
  background: linear-gradient(135deg, #22D3EE 0%, #14B8A6 100%);
  box-shadow: 0 16rpx 34rpx rgba(34, 211, 238, 0.28);
}

.quick-add-modal {
  background: rgba(2, 6, 23, 0.72);
}

.quick-add-content {
  background: #0B1020;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.quick-account-item {
  background: rgba(15, 23, 42, 0.78);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.quick-icon {
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.quick-name {
  color: #CBD5E1;
}

.cancel-btn {
  color: #8EA0B8;
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.asset-overview {
  padding: 26rpx 24rpx 28rpx;
  margin-bottom: 22rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(34, 211, 238, 0.16), transparent 38%),
    linear-gradient(180deg, rgba(8, 17, 32, 0.92), rgba(7, 12, 24, 0.98));
}

.asset-overview-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.asset-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #8EA0B8;
  font-size: 24rpx;
  font-weight: 700;
}

.asset-eye {
  color: #8EA0B8;
  font-size: 22rpx;
}

.asset-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.asset-analysis-link {
  flex-shrink: 0;
  color: #12D8C8;
  font-size: 24rpx;
  font-weight: 800;
}

.total-amount {
  color: #F8FAFC;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 800;
  letter-spacing: 0;
  text-shadow: 0 12rpx 32rpx rgba(248, 250, 252, 0.08);
}

.asset-metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 28rpx;
}

.asset-metric {
  min-width: 0;
}

.asset-metric-label {
  margin-bottom: 8rpx;
  color: #8EA0B8;
  font-size: 22rpx;
  font-weight: 650;
}

.asset-metric-value {
  color: #E5EEF8;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.asset-metric-value.debt {
  color: #FF6268;
}

.asset-metric-value.net {
  color: #8AE650;
}

.account-group-card {
  margin-bottom: 20rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.72);
}

.account-group-card .category-header {
  padding: 0 0 16rpx;
}

.account-group-card .category-name {
  font-size: 28rpx;
}

.account-group-card .category-total {
  color: #D7E1EC;
  font-size: 26rpx;
}

.account-item {
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  border-radius: 14rpx;
  box-shadow: none;
}

.account-item.asset-account {
  background: linear-gradient(135deg, rgba(20, 184, 166, 0.24), rgba(14, 116, 144, 0.22));
}

.account-item.debt-account {
  background: linear-gradient(135deg, rgba(248, 113, 113, 0.20), rgba(127, 29, 29, 0.20));
}

.account-content {
  min-width: 0;
  padding: 0;
}

.account-left {
  min-width: 0;
}

.account-icon-wrapper {
  width: 58rpx;
  height: 58rpx;
  margin-right: 18rpx;
  border-radius: 50%;
}

.account-icon-wrapper .badge-glyph {
  font-size: 22rpx;
}

.account-icon-wrapper.bank-logo .badge-glyph {
  font-size: 15rpx;
}

.account-name-row {
  margin-bottom: 4rpx;
}

.account-name {
  color: #F1F5F9;
  font-size: 27rpx;
  font-weight: 800;
}

.account-note {
  color: #A6B3C2;
  font-size: 22rpx;
}

.account-right {
  width: 210rpx;
  position: relative;
  padding-right: 26rpx;
}

.account-balance {
  margin-bottom: 0;
  color: #E5EEF8;
  font-size: 30rpx;
}

.account-balance.debt {
  color: #FF6268;
}

.account-actions {
  margin-top: 8rpx;
  opacity: 0.72;
}

.action-btn {
  min-width: auto;
  padding: 0;
  background: transparent;
  color: #9EACBA;
  font-size: 20rpx;
}

.action-btn.delete {
  background: transparent;
  color: #FF7B81;
}

.account-chevron {
  position: absolute;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  color: #C7D2DE;
  font-size: 42rpx;
  line-height: 1;
}

.add-quick-account {
  margin-top: 4rpx;
  border-radius: 12rpx;
  background: rgba(34, 211, 238, 0.06);
}

.brand-logo-image {
  width: 48rpx;
  height: 48rpx;
  display: block;
  flex-shrink: 0;
}
