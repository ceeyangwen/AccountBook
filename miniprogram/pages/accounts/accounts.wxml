<view class="page-container">
  <view class="asset-overview">
    <view class="asset-overview-top">
      <view class="asset-title-wrap">
        <text class="asset-eye">◉</text>
        <text class="asset-title">资产总览（元）</text>
      </view>
      <view class="asset-analysis-link">资产分析 ›</view>
    </view>

    <view class="total-amount" wx:if="{{totalBalance !== null}}">
      ¥{{netAssetBalance}}
    </view>
    <view class="total-amount" wx:else>
      加载中...
    </view>

    <view class="asset-metric-grid">
      <view class="asset-metric">
        <view class="asset-metric-label">总资产</view>
        <view class="asset-metric-value">¥{{totalAssetBalance}}</view>
      </view>
      <view class="asset-metric">
        <view class="asset-metric-label">总负债</view>
        <view class="asset-metric-value debt">-¥{{totalDebtBalance}}</view>
      </view>
      <view class="asset-metric">
        <view class="asset-metric-label">净资产</view>
        <view class="asset-metric-value net">¥{{netAssetBalance}}</view>
      </view>
    </view>
  </view>

  <view class="account-list" id="accountList">
    <view wx:for="{{groupedAccounts}}" wx:key="category" class="account-group-card" wx:for-index="groupIndex">
      <view class="category-header flex flex-between" bindtap="toggleCategoryCollapse" data-category="{{item.categoryInfo.name}}">
        <view class="category-name">
          <view class="category-collapse-icon">{{item.isCollapsed ? '›' : '⌄'}}</view>
          <view class="category-icon badge-mark {{item.categoryInfo.badge.className}}" style="background: {{item.categoryInfo.badge.background}}; border-color: {{item.categoryInfo.badge.color}}; color: {{item.categoryInfo.badge.color}};">
            <text class="badge-glyph">{{item.categoryInfo.badge.logoText || item.categoryInfo.badge.symbol}}</text>
            <text class="badge-mark-text">{{item.categoryInfo.badge.label}}</text>
          </view>
          {{item.categoryInfo.name}}（{{item.accounts.length}}）
        </view>
        <view class="category-total">¥{{item.totalBalance}}</view>
      </view>
      
      <view wx:if="{{!item.isCollapsed}}" wx:for="{{item.accounts}}" wx:for-item="account" wx:for-index="accountIndex" wx:key="id" 
            class="account-item {{account.categoryInfo.type === 'debt' || account.categoryInfo.type === 'credit' ? 'debt-account' : 'asset-account'}} {{isEditing ? 'editing' : ''}}"
            data-index="{{accountIndex}}" 
            data-category="{{item.categoryInfo.name}}"
            data-category-index="{{groupIndex}}"
            data-id="{{account.id}}">
        <view class="drag-handle" wx:if="{{isEditing}}">
          <text class="drag-icon">☰</text>
        </view>
        <view class="account-content" bindtap="{{isEditing ? '' : 'viewAccountDetail'}}" data-account="{{account}}">
          <view class="account-left flex flex-center">
            <view class="account-icon-wrapper badge-mark {{account.badge.className}}" style="background: {{account.badge.background}}; border-color: {{account.badge.color}}; color: {{account.badge.color}};">
              <block wx:if="{{account.badge.iconImage}}">
                <image class="brand-logo-image" src="{{account.badge.iconImage}}" mode="aspectFit"></image>
              </block>
              <block wx:else>
                <text class="badge-glyph">{{account.badge.symbol}}</text>
                <text class="badge-mark-text">{{account.badge.label}}</text>
              </block>
            </view>
            <view class="account-info">
              <view class="account-name-row">
                <view class="account-name">{{account.name}}</view>
                <view class="hidden-account-label" wx:if="{{account.isHidden === true}}">隐藏</view>
                <view class="exclude-total-label" wx:if="{{account.includeInTotal === false}}">不计入总资产</view>
              </view>
              <view class="account-note" wx:if="{{account.note}}">{{account.note}}</view>
              <view class="account-note" wx:else>{{account.categoryInfo.type === 'debt' || account.categoryInfo.type === 'credit' ? '剩余应还' : '可用余额'}}</view>
            </view>
          </view>
          <view class="account-right">
            <view class="account-balance {{account.categoryInfo.type === 'debt' || account.categoryInfo.type === 'credit' ? 'debt' : ''}}">
              <block wx:if="{{account.categoryInfo.type === 'debt' || account.categoryInfo.type === 'credit'}}">-¥{{account.balance}}</block>
              <block wx:else>¥{{account.balance}}</block>
            </view>
            <view class="account-actions" wx:if="{{!isEditing}}">
              <text class="action-btn" bindtap="editAccount" data-account="{{account}}">编辑</text>
              <text class="action-btn delete" bindtap="deleteAccount" data-id="{{account.id}}" data-name="{{account.name}}">删除</text>
            </view>
            <view class="drag-actions" wx:if="{{isEditing}}">
              <text class="drag-btn up {{accountIndex === 0 ? 'disabled' : ''}}" 
                    catchtap="moveUp" 
                    data-group-index="{{groupIndex}}" 
                    data-index="{{accountIndex}}">↑</text>
              <text class="drag-btn down {{accountIndex === item.accounts.length - 1 ? 'disabled' : ''}}" 
                    catchtap="moveDown" 
                    data-group-index="{{groupIndex}}" 
                    data-index="{{accountIndex}}">↓</text>
            </view>
            <view class="account-chevron" wx:if="{{!isEditing}}">›</view>
          </view>
        </view>
      </view>
      
      <view wx:if="{{!item.isCollapsed}}" class="add-quick-account" bindtap="showQuickAdd" data-category="{{item.categoryInfo.name}}">
        <text class="add-icon">+</text> 快速添加
      </view>
    </view>
    
    <view wx:if="{{groupedAccounts.length === 0 && totalBalance !== null}}" class="empty-tip">
      <view class="empty-tip-text">{{hiddenAccountsCount > 0 && !showHiddenAccounts ? '暂无可见账户' : '还没有账户'}}</view>
      <view class="empty-tip-subtext">{{hiddenAccountsCount > 0 && !showHiddenAccounts ? '可在我的页面打开显示隐藏账号' : '点击右下角按钮添加第一个账户'}}</view>
    </view>
  </view>

  <view class="floating-btn" wx:if="{{!isEditing}}" bindtap="addAccount">
    <view class="floating-icon">+</view>
  </view>

  <view class="quick-add-modal" wx:if="{{showQuickAdd}}" bindtap="hideQuickAdd">
    <view class="quick-add-content" catchtap="stopPropagation">
      <view class="quick-add-title">快速添加 {{currentCategory}}</view>
      <view class="quick-account-list">
        <view wx:for="{{quickAccounts}}" wx:key="name" class="quick-account-item" bindtap="quickAddAccount" data-account="{{item}}">
          <view class="quick-icon badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
            <block wx:if="{{item.badge.iconImage}}">
              <image class="brand-logo-image" src="{{item.badge.iconImage}}" mode="aspectFit"></image>
            </block>
            <block wx:else>
              <text class="badge-glyph">{{item.badge.symbol}}</text>
              <text class="badge-mark-text">{{item.badge.label}}</text>
            </block>
          </view>
          <text class="quick-name">{{item.name}}</text>
        </view>
      </view>
      <view class="cancel-btn" bindtap="hideQuickAdd">取消</view>
    </view>
  </view>
</view>
