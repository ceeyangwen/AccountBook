<view class="page-container">
  <view class="period-selector card p-15">
    <view class="period-item {{period === 'week' ? 'active' : ''}}" bindtap="switchPeriod" data-period="week">
      周
    </view>
    <view class="period-item {{period === 'month' ? 'active' : ''}}" bindtap="switchPeriod" data-period="month">
      月
    </view>
    <view class="period-item {{period === 'year' ? 'active' : ''}}" bindtap="switchPeriod" data-period="year">
      年
    </view>
    <view class="period-item {{period === 'custom' ? 'active' : ''}}" bindtap="switchPeriod" data-period="custom">
      自定义
    </view>
  </view>

  <view class="period-navigator">
    <view class="period-arrow">‹</view>
    <view class="period-current">{{period === 'year' ? '本年' : period === 'week' ? '本周' : period === 'custom' ? '自定义' : '本月'}}</view>
    <view class="period-arrow">›</view>
  </view>

  <view class="summary-card analytics-card card p-20 mt-20">
    <view class="summary-header">
      <view class="summary-title">{{period === 'year' ? '本年' : period === 'week' ? '本周' : period === 'custom' ? '自定义' : '本月'}}收支概览</view>
    </view>
    <view class="summary-data flex flex-between mt-20">
      <view class="summary-item">
        <view class="summary-label">总收入</view>
        <view class="summary-value income">¥{{totalIncome}}</view>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <view class="summary-label">总支出</view>
        <view class="summary-value expense">¥{{totalExpense}}</view>
      </view>
    </view>
    <view class="balance-section mt-20">
      <view class="balance-label">结余</view>
      <view class="balance-value {{balance >= 0 ? 'income' : 'expense'}}">
        {{balance >= 0 ? '+' : ''}}¥{{balance}}
      </view>
    </view>
  </view>

  <view class="trend-section mt-20">
    <view class="section-title-row">
      <view class="section-title">收支趋势</view>
      <view class="section-unit">单位：元</view>
    </view>
    <view class="trend-card analytics-card card p-20">
      <view wx:if="{{assetTrend.length === 0}}" class="empty-state">
        <view class="empty-icon">AST</view>
        <view class="empty-text">暂无资产数据</view>
      </view>
      <view wx:else class="line-chart">
        <view class="chart-header">
          <view class="chart-heading">
            <text class="chart-label">{{period === 'year' ? '每月' : '每日'}}资产变化</text>
            <text class="chart-subtitle">点击或滑动图表查看详情</text>
          </view>
          <view class="trend-current">
            <text class="trend-current-label">期末资产</text>
            <text class="trend-current-value">¥{{assetTrendLatest}}</text>
            <text class="trend-change {{assetTrendDeltaClass}}">{{assetTrendDelta}}</text>
          </view>
        </view>
        
        <view class="asset-chart-shell">
          <canvas canvas-id="assetTrendCanvas"
                  class="asset-trend-canvas"
                  disable-scroll="true"
                  bindtouchstart="onTrendTouch"
                  bindtouchmove="onTrendTouch"></canvas>
        </view>
        
        <view class="trend-detail-panel" wx:if="{{selectedTrend}}">
          <view class="trend-detail-main">
            <text class="trend-detail-date">{{selectedTrend.label}}</text>
            <text class="trend-detail-balance">¥{{selectedTrend.balance}}</text>
          </view>
          <view class="trend-detail-grid">
            <view class="trend-detail-item">
              <text class="detail-label">收入</text>
              <text class="detail-value income">¥{{selectedTrend.income}}</text>
            </view>
            <view class="trend-detail-item">
              <text class="detail-label">支出</text>
              <text class="detail-value expense">¥{{selectedTrend.expense}}</text>
            </view>
            <view class="trend-detail-item">
              <text class="detail-label">较上期</text>
              <text class="detail-value {{selectedTrend.changeClass}}">{{selectedTrend.changeText}}</text>
            </view>
          </view>
        </view>
        
        <view class="trend-footer">
          <view class="footer-item">
            <text class="x-label">{{assetTrend[0].label}}</text>
            <text class="summary-text">期初</text>
            <text class="summary-amount">¥{{assetTrend[0].balance}}</text>
          </view>
          <view class="footer-divider"></view>
          <view class="footer-item">
            <text class="x-label">{{assetTrend[assetTrend.length-1].label}}</text>
            <text class="summary-text">期末</text>
            <text class="summary-amount {{assetTrend[assetTrend.length-1].balance >= assetTrend[0].balance ? 'income' : 'expense'}}">¥{{assetTrend[assetTrend.length-1].balance}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="category-section mt-20">
    <view class="section-title-row">
      <view class="section-title">支出分类</view>
      <view class="category-toggle">
        <text class="toggle-active">支出</text>
        <text>收入</text>
      </view>
    </view>
    
    <view wx:if="{{expenseCategoryList.length === 0}}" class="empty-state card p-20">
      <view class="empty-icon">CAT</view>
      <view class="empty-text">{{period === 'year' ? '本年' : period === 'week' ? '本周' : period === 'custom' ? '自定义' : '本月'}}暂无支出记录</view>
    </view>
    
    <view wx:else>
      <view class="pie-chart-section analytics-card card p-20">
        <view class="pie-chart-wrapper">
          <view class="pie-chart" style="background: conic-gradient({{pieGradient}});">
            <view class="pie-center">
              <view class="pie-total-label">总支出</view>
              <view class="pie-total-value">¥{{totalExpense}}</view>
            </view>
          </view>
        </view>
        <view class="pie-legend">
          <view wx:for="{{expenseCategoryList}}" 
                wx:key="id" 
                class="legend-item {{item.selected ? 'selected' : ''}}"
                bindtap="selectPieItem"
                data-index="{{index}}">
            <view class="legend-color" style="background: {{item.color}};"></view>
            <view class="legend-text">{{item.name}}</view>
            <view class="legend-percent">{{item.percent}}%</view>
          </view>
        </view>
      </view>
      
      <view class="category-list mt-20">
        <view wx:for="{{expenseCategoryList}}" wx:key="id" wx:for-index="categoryIndex" class="category-card analytics-card card p-20">
          <view class="category-main" bindtap="toggleCategoryDrilldown" data-index="{{categoryIndex}}">
            <view class="category-header">
              <view class="category-icon-wrapper badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
                <image wx:if="{{item.badge.iconImage}}" class="badge-image" src="{{item.badge.iconImage}}" mode="aspectFit"></image>
                <block wx:else>
                  <text class="badge-glyph">{{item.badge.symbol}}</text>
                  <text class="badge-mark-text">{{item.badge.label}}</text>
                </block>
              </view>
              <view class="category-info">
                <view class="category-name">{{item.name}}</view>
                <view class="category-percent">{{item.percent}}%</view>
              </view>
              <view class="category-actions">
                <view class="category-amount">¥{{item.amount}}</view>
                <view class="category-drill-toggle">{{item.isExpanded ? '收起' : '查看明细'}}</view>
              </view>
            </view>
            <view class="category-bar">
              <view class="bar-track">
                <view class="bar-fill" style="width: {{item.percent}}%; background: {{item.color}};"></view>
              </view>
            </view>
          </view>
          <view class="category-child-list" wx:if="{{item.children.length > 0}}">
            <view wx:for="{{item.children}}" wx:key="id" wx:for-item="child" class="category-child-row {{item.activeChildCategoryId === child.id ? 'active' : ''}}" catchtap="toggleChildDrilldown" data-category-index="{{categoryIndex}}" data-child-id="{{child.id}}">
              <view class="category-child-left">
                <view class="category-child-dot" style="background: {{child.color}};"></view>
                <text class="category-child-name">{{child.name}}</text>
              </view>
              <view class="category-child-right">
                <text class="category-child-percent">{{child.percent}}%</text>
                <text class="category-child-amount">¥{{child.amount}}</text>
              </view>
            </view>
          </view>
          <view class="category-drilldown" wx:if="{{item.isExpanded}}">
            <view class="drilldown-header">
              <text class="drilldown-title">{{item.drilldownTitle}}</text>
              <text class="drilldown-count">{{item.drillRecords.length}}笔</text>
            </view>
            <view class="drill-record-list">
              <view wx:for="{{item.drillRecords}}" wx:key="id" wx:for-item="drillRecord" class="drill-record-row" catchtap="goToDrilldownRecord" data-record-id="{{drillRecord.id}}">
                <view class="drill-record-left">
                  <view class="drill-record-date">{{drillRecord.dateText}}</view>
                  <view class="drill-record-meta">
                    <text>{{drillRecord.accountName}}</text>
                    <text wx:if="{{drillRecord.note}}"> · {{drillRecord.note}}</text>
                  </view>
                </view>
                <view class="drill-record-amount">¥{{drillRecord.amount}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="category-ranking-card">
        <view class="ranking-header">
          <view class="section-title">{{period === 'year' ? '本年' : period === 'week' ? '本周' : period === 'custom' ? '自定义' : '本月'}}支出排行</view>
          <view class="section-more">全部 ›</view>
        </view>
        <view wx:for="{{expenseCategoryList}}" wx:key="id" wx:for-index="rankIndex" class="ranking-row">
          <view class="ranking-left">
            <text class="ranking-index">{{rankIndex + 1}}</text>
            <view class="ranking-badge badge-mark {{item.badge.className}}" style="background: {{item.badge.background}}; border-color: {{item.badge.color}}; color: {{item.badge.color}};">
              <image wx:if="{{item.badge.iconImage}}" class="badge-image" src="{{item.badge.iconImage}}" mode="aspectFit"></image>
              <block wx:else>
                <text class="badge-glyph">{{item.badge.symbol}}</text>
                <text class="badge-mark-text">{{item.badge.label}}</text>
              </block>
            </view>
            <text class="ranking-name">{{item.name}}</text>
          </view>
          <view class="ranking-bar">
            <view class="ranking-bar-fill" style="width: {{item.percent}}%;"></view>
          </view>
          <view class="ranking-amount">¥{{item.amount}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
