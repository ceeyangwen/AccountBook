.page-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.period-selector {
  display: flex;
  align-items: center;
  padding: 8rpx;
  background: #FFF5F5;
}

.period-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.period-item.active {
  background: #FF6B6B;
  color: white;
  font-weight: 600;
}

.period-divider {
  width: 2rpx;
  height: 40rpx;
  background: #FFE8E8;
}

.summary-card {
  text-align: center;
}

.summary-header {
  margin-bottom: 10rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.summary-data {
  align-items: center;
}

.summary-item {
  flex: 1;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
}

.summary-value.expense {
  color: #2ECC71;
}

.summary-value.income {
  color: #E74C3C;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: #FFE8E8;
}

.balance-section {
  padding-top: 20rpx;
  border-top: 2rpx dashed #FFE8E8;
}

.balance-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.balance-value {
  font-size: 44rpx;
  font-weight: 700;
}

.balance-value.expense {
  color: #2ECC71;
}

.balance-value.income {
  color: #E74C3C;
}

.trend-section {
  margin-bottom: 20rpx;
}

.trend-card {
  border-radius: 16rpx;
}

.line-chart {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.chart-heading {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chart-label {
  font-size: 28rpx;
  color: #2F3442;
  font-weight: 600;
}

.chart-subtitle {
  font-size: 22rpx;
  color: #98A1B2;
  line-height: 1.3;
}

.trend-current {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.trend-current-label {
  font-size: 22rpx;
  color: #98A1B2;
}

.trend-current-value {
  font-size: 34rpx;
  color: #1F2937;
  font-weight: 700;
  line-height: 1.1;
}

.trend-change {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
}

.trend-change.income,
.detail-value.income {
  color: #E74C3C;
}

.trend-change.expense,
.detail-value.expense {
  color: #2ECC71;
}

.asset-chart-shell {
  position: relative;
  height: 360rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEF1F6;
  overflow: hidden;
}

.asset-trend-canvas {
  width: 100%;
  height: 360rpx;
  display: block;
}

.trend-detail-panel {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #F8FAFF;
  border: 1rpx solid #E6ECFA;
}

.trend-detail-main {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.trend-detail-date {
  font-size: 26rpx;
  color: #647084;
  font-weight: 600;
}

.trend-detail-balance {
  min-width: 0;
  font-size: 34rpx;
  color: #1F2937;
  font-weight: 700;
  white-space: nowrap;
}

.trend-detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.trend-detail-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #98A1B2;
}

.detail-value {
  min-width: 0;
  font-size: 24rpx;
  color: #2F3442;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trend-footer {
  display: grid;
  grid-template-columns: 1fr 2rpx 1fr;
  align-items: stretch;
  column-gap: 0;
  padding: 12rpx 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.footer-item {
  min-width: 0;
  min-height: 116rpx;
  display: grid;
  grid-template-rows: 30rpx 30rpx 44rpx;
  justify-items: center;
  align-items: center;
  row-gap: 2rpx;
}

.x-label {
  font-size: 22rpx;
  color: #999;
  line-height: 1.2;
}

.summary-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.2;
}

.summary-amount {
  max-width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.summary-amount.income {
  color: #E74C3C;
}

.summary-amount.expense {
  color: #2ECC71;
}

.footer-divider {
  width: 2rpx;
  height: 112rpx;
  background: #f0f0f0;
  justify-self: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.category-section {
  margin-bottom: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  background: white;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.pie-chart-section {
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pie-chart-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 300rpx;
}

.pie-chart {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pie-center {
  position: relative;
  text-align: center;
  background: white;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 1;
}

.pie-total-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.pie-total-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2ECC71;
}

.pie-legend {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-radius: 8rpx;
  transition: background 0.2s;
}

.legend-item.selected {
  background: #FFF5F5;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.legend-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.legend-percent {
  font-size: 24rpx;
  color: #999;
  min-width: 80rpx;
  text-align: right;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card {
  border-radius: 16rpx;
}

.category-main {
  width: 100%;
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.category-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.category-icon-wrapper .badge-glyph {
  font-size: 40rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.category-percent {
  font-size: 24rpx;
  color: #999;
}

.category-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.category-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.category-drill-toggle {
  font-size: 22rpx;
  color: #FF6B6B;
}

.category-bar {
  width: 100%;
}

.bar-track {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.category-child-list {
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.category-child-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 10rpx;
  border-radius: 8rpx;
}

.category-child-row.active {
  background: #FFF2F2;
}

.category-child-left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.category-child-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.category-child-name {
  font-size: 26rpx;
  color: #555;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-child-right {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  flex-shrink: 0;
}

.category-child-percent {
  font-size: 22rpx;
  color: #999;
}

.category-child-amount {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.category-drilldown {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.drilldown-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.drilldown-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.drilldown-count {
  font-size: 22rpx;
  color: #999;
}

.drill-record-list {
  display: flex;
  flex-direction: column;
}

.drill-record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.drill-record-row:last-child {
  border-bottom: none;
}

.drill-record-left {
  min-width: 0;
  flex: 1;
}

.drill-record-date {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.drill-record-meta {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drill-record-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF6B6B;
  flex-shrink: 0;
}

/* Dark fintech statistics overrides */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(34, 211, 238, 0.12), transparent 34%),
    radial-gradient(circle at 92% 8%, rgba(20, 184, 166, 0.10), transparent 30%),
    linear-gradient(180deg, #07101D 0%, #070B14 100%);
}

.period-selector,
.summary-card,
.trend-card,
.pie-chart-section,
.category-card {
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: none;
}

.period-selector {
  border-radius: 18rpx;
}

.period-item {
  color: #8EA0B8;
}

.period-item.active {
  background: linear-gradient(135deg, #22D3EE 0%, #14B8A6 100%);
  color: #06111F;
}

.period-divider,
.summary-divider {
  background: rgba(148, 163, 184, 0.14);
}

.summary-title,
.section-title,
.chart-label,
.trend-current-value,
.trend-detail-balance,
.category-name,
.category-child-amount,
.drilldown-title,
.drill-record-date {
  color: #E5EEF8;
}

.summary-label,
.balance-label,
.chart-subtitle,
.trend-current-label,
.trend-detail-date,
.detail-label,
.category-percent,
.legend-text,
.legend-percent,
.category-child-percent,
.drilldown-count,
.drill-record-meta,
.empty-text {
  color: #8EA0B8;
}

.summary-value.expense,
.balance-value.expense,
.trend-change.expense,
.detail-value.expense {
  color: #22C55E;
}

.summary-value.income,
.balance-value.income,
.trend-change.income,
.detail-value.income,
.drill-record-amount {
  color: #EF4444;
}

.balance-section,
.category-child-list,
.category-drilldown {
  border-top-color: rgba(148, 163, 184, 0.14);
}

.asset-chart-shell {
  background: #101827;
  border-color: rgba(148, 163, 184, 0.16);
}

.trend-detail-panel {
  background: rgba(2, 6, 23, 0.22);
  border-color: rgba(34, 211, 238, 0.16);
}

.trend-footer {
  border-top-color: rgba(148, 163, 184, 0.14);
}

.footer-divider {
  background: rgba(148, 163, 184, 0.14);
}

.x-label,
.summary-text {
  color: #8EA0B8;
}

.summary-amount {
  color: #E5EEF8;
}

.pie-center {
  background: #0B1020;
  border-color: rgba(148, 163, 184, 0.16);
}

.pie-total-label {
  color: #8EA0B8;
}

.pie-total-value {
  color: #E5EEF8;
}

.legend-item {
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.legend-item.selected {
  background: rgba(34, 211, 238, 0.08);
  border-color: rgba(34, 211, 238, 0.28);
}

.category-icon-wrapper {
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 18rpx;
  box-shadow: inset 0 0 20rpx rgba(255, 255, 255, 0.04);
}

.category-icon-wrapper .badge-glyph {
  font-size: 30rpx;
  font-weight: 800;
}

.category-drill-toggle {
  color: #67E8F9;
}

.bar-track {
  background: rgba(148, 163, 184, 0.14);
}

.category-child-row.active {
  background: rgba(34, 211, 238, 0.08);
}

.category-child-name {
  color: #CBD5E1;
}

.drill-record-row {
  border-bottom-color: rgba(148, 163, 184, 0.10);
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(34, 211, 238, 0.28);
  background: rgba(34, 211, 238, 0.10);
  color: #67E8F9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.period-selector {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  padding: 6rpx;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.88);
}

.period-item {
  min-width: 0;
  padding: 14rpx 0;
  border-radius: 10rpx;
  font-size: 25rpx;
  font-weight: 750;
}

.period-item.active {
  color: #EFFFFD;
  background: linear-gradient(135deg, #15CFC0 0%, #10B9A9 100%);
  box-shadow: 0 8rpx 20rpx rgba(18, 216, 200, 0.26);
}

.period-navigator {
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  align-items: center;
  margin: 18rpx 0 18rpx;
  color: #E5EEF8;
}

.period-current {
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.period-arrow {
  color: #8EA0B8;
  font-size: 44rpx;
  line-height: 1;
  text-align: center;
}

.analytics-card {
  background: rgba(15, 23, 42, 0.84);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: 16rpx;
  box-shadow: none;
}

.summary-value.expense,
.balance-value.expense,
.trend-change.expense,
.detail-value.expense,
.drill-record-amount {
  color: #FF6268;
}

.summary-value.income,
.balance-value.income,
.trend-change.income,
.detail-value.income {
  color: #18CDAA;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.section-title-row .section-title {
  margin-bottom: 0;
}

.section-unit,
.section-more {
  flex-shrink: 0;
  color: #8EA0B8;
  font-size: 22rpx;
  font-weight: 650;
}

.category-toggle {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #8EA0B8;
  font-size: 24rpx;
  font-weight: 750;
}

.category-toggle .toggle-active {
  min-width: 70rpx;
  padding: 8rpx 14rpx;
  border: 1rpx solid rgba(18, 216, 200, 0.48);
  border-radius: 8rpx;
  color: #12D8C8;
  text-align: center;
}

.pie-chart-section {
  display: grid;
  grid-template-columns: 260rpx minmax(0, 1fr);
  align-items: center;
  gap: 22rpx;
}

.pie-chart-wrapper {
  height: 260rpx;
}

.pie-chart {
  width: 230rpx;
  height: 230rpx;
}

.pie-center {
  width: 130rpx;
  height: 130rpx;
}

.pie-total-value {
  color: #E5EEF8;
  font-size: 28rpx;
}

.legend-item {
  padding: 8rpx 0;
  border: 0;
  background: transparent;
}

.legend-color {
  width: 18rpx;
  height: 18rpx;
  border-radius: 5rpx;
}

.category-ranking-card {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.84);
}

.ranking-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.ranking-header .section-title {
  margin-bottom: 0;
}

.ranking-row {
  display: grid;
  grid-template-columns: 220rpx minmax(0, 1fr) 150rpx;
  align-items: center;
  gap: 18rpx;
  padding: 14rpx 0;
}

.ranking-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ranking-index {
  width: 28rpx;
  color: #CBD5E1;
  font-size: 24rpx;
  text-align: center;
}

.ranking-badge {
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
}

.ranking-badge .badge-glyph {
  top: 10rpx;
  font-size: 20rpx;
}

.ranking-badge .badge-mark-text {
  display: none;
}

.ranking-name {
  min-width: 0;
  color: #E5EEF8;
  font-size: 25rpx;
  font-weight: 750;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ranking-bar {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.16);
  overflow: hidden;
}

.ranking-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #FF6268, #FF7B81);
}

.ranking-amount {
  color: #E5EEF8;
  font-size: 25rpx;
  font-weight: 750;
  text-align: right;
  white-space: nowrap;
}
