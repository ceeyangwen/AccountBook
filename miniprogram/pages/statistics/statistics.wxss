.page-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.period-selector {
  display: flex;
  align-items: center;
  padding: 8rpx;
  background: #FFF5F5;
}

.period-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.period-item.active {
  background: #FF6B6B;
  color: white;
  font-weight: 600;
}

.period-divider {
  width: 2rpx;
  height: 40rpx;
  background: #FFE8E8;
}

.summary-card {
  text-align: center;
}

.summary-header {
  margin-bottom: 10rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.summary-data {
  align-items: center;
}

.summary-item {
  flex: 1;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
}

.summary-value.expense {
  color: #2ECC71;
}

.summary-value.income {
  color: #E74C3C;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: #FFE8E8;
}

.balance-section {
  padding-top: 20rpx;
  border-top: 2rpx dashed #FFE8E8;
}

.balance-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.balance-value {
  font-size: 44rpx;
  font-weight: 700;
}

.balance-value.expense {
  color: #2ECC71;
}

.balance-value.income {
  color: #E74C3C;
}

.trend-section {
  margin-bottom: 20rpx;
}

.trend-card {
  border-radius: 16rpx;
}

.line-chart {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.chart-heading {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chart-label {
  font-size: 28rpx;
  color: #2F3442;
  font-weight: 600;
}

.chart-subtitle {
  font-size: 22rpx;
  color: #98A1B2;
  line-height: 1.3;
}

.trend-current {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.trend-current-label {
  font-size: 22rpx;
  color: #98A1B2;
}

.trend-current-value {
  font-size: 34rpx;
  color: #1F2937;
  font-weight: 700;
  line-height: 1.1;
}

.trend-change {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
}

.trend-change.income,
.detail-value.income {
  color: #E74C3C;
}

.trend-change.expense,
.detail-value.expense {
  color: #2ECC71;
}

.asset-chart-shell {
  position: relative;
  height: 360rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEF1F6;
  overflow: hidden;
}

.asset-trend-canvas {
  width: 100%;
  height: 360rpx;
  display: block;
}

.trend-detail-panel {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #F8FAFF;
  border: 1rpx solid #E6ECFA;
}

.trend-detail-main {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.trend-detail-date {
  font-size: 26rpx;
  color: #647084;
  font-weight: 600;
}

.trend-detail-balance {
  min-width: 0;
  font-size: 34rpx;
  color: #1F2937;
  font-weight: 700;
  white-space: nowrap;
}

.trend-detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.trend-detail-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #98A1B2;
}

.detail-value {
  min-width: 0;
  font-size: 24rpx;
  color: #2F3442;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trend-footer {
  display: grid;
  grid-template-columns: 1fr 2rpx 1fr;
  align-items: stretch;
  column-gap: 0;
  padding: 12rpx 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 8rpx;
}

.footer-item {
  min-width: 0;
  min-height: 116rpx;
  display: grid;
  grid-template-rows: 30rpx 30rpx 44rpx;
  justify-items: center;
  align-items: center;
  row-gap: 2rpx;
}

.x-label {
  font-size: 22rpx;
  color: #999;
  line-height: 1.2;
}

.summary-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.2;
}

.summary-amount {
  max-width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.summary-amount.income {
  color: #E74C3C;
}

.summary-amount.expense {
  color: #2ECC71;
}

.footer-divider {
  width: 2rpx;
  height: 112rpx;
  background: #f0f0f0;
  justify-self: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.category-section {
  margin-bottom: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 40rpx;
  background: white;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.pie-chart-section {
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pie-chart-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  height: 300rpx;
}

.pie-chart {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pie-center {
  position: relative;
  text-align: center;
  background: white;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 1;
}

.pie-total-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.pie-total-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2ECC71;
}

.pie-legend {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-radius: 8rpx;
  transition: background 0.2s;
}

.legend-item.selected {
  background: #FFF5F5;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.legend-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.legend-percent {
  font-size: 24rpx;
  color: #999;
  min-width: 80rpx;
  text-align: right;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card {
  border-radius: 16rpx;
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.category-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.category-emoji {
  font-size: 40rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.category-percent {
  font-size: 24rpx;
  color: #999;
}

.category-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.category-bar {
  width: 100%;
}

.bar-track {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}
