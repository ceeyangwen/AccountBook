.page-container {
  padding: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-icon {
  font-size: 64rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: #999;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
}

.menu-left {
  flex: 1;
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrapper.export {
  background: rgba(78, 205, 196, 0.15);
}

.menu-icon-wrapper.import {
  background: rgba(255, 107, 107, 0.15);
}

.menu-icon-wrapper.clear {
  background: rgba(153, 153, 153, 0.15);
}

.menu-icon-wrapper.category {
  background: rgba(255, 193, 7, 0.15);
}

.menu-icon-wrapper.privacy {
  background: rgba(102, 126, 234, 0.15);
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.menu-text.text-danger {
  color: #E74C3C;
}

.menu-arrow {
  font-size: 48rpx;
  color: #CCC;
  font-weight: 300;
}

.info-card {
  background: #FFF5F5;
  border-color: #FFE8E8;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-content text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.version-section {
  text-align: center;
  padding: 20rpx 0;
}

.version-text {
  font-size: 26rpx;
  color: #999;
}

/* Dark fintech settings overrides */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 80rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(34, 211, 238, 0.12), transparent 34%),
    linear-gradient(180deg, #07101D 0%, #070B14 100%);
}

.user-card,
.menu-item,
.info-card {
  background: rgba(15, 23, 42, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: none;
}

.user-avatar {
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.18), rgba(20, 184, 166, 0.18));
  border: 1rpx solid rgba(34, 211, 238, 0.28);
}

.avatar-icon {
  color: #67E8F9;
  font-size: 34rpx;
  font-weight: 900;
}

.user-name,
.menu-text,
.info-title {
  color: #E5EEF8;
}

.user-desc,
.info-content text,
.version-text {
  color: #8EA0B8;
}

.menu-icon-wrapper {
  border-radius: 18rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.menu-icon-wrapper.export,
.menu-icon-wrapper.import,
.menu-icon-wrapper.category,
.menu-icon-wrapper.privacy,
.menu-icon-wrapper.refresh,
.menu-icon-wrapper.debug {
  background: rgba(34, 211, 238, 0.10);
}

.menu-icon-wrapper.clear {
  background: rgba(248, 113, 113, 0.10);
}

.menu-icon {
  color: #67E8F9;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-icon-wrapper.clear .menu-icon,
.menu-text.text-danger {
  color: #F87171;
}

.menu-arrow {
  color: #64748B;
}
