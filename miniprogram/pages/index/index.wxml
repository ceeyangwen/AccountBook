<view class="page-container">
  <view class="month-dashboard-card card">
    <picker class="summary-month-picker" mode="date" fields="month" value="{{selectedMonthValue}}" start="{{monthPickerStart}}" end="{{monthPickerEnd}}" bindchange="onMonthChange">
      <view class="summary-header flex flex-between">
        <view class="summary-month-selector">
          <text>{{currentMonth}}</text>
          <text class="selector-arrow">⌄</text>
        </view>
        <view class="calendar-mark">□</view>
      </view>
    </picker>

    <view class="summary-data">
      <view class="summary-item expense-panel">
        <view class="summary-label">本月支出</view>
        <view class="summary-value expense {{monthlyExpenseAmountSizeClass}}">-¥{{monthlyExpense}}</view>
        <view class="budget-track">
          <view class="budget-progress expense-progress" style="width: {{expenseBudgetRate}}%;"></view>
        </view>
        <view class="budget-meta">
          <text>预算 ¥{{monthlyExpenseBudget}}</text>
          <text>{{expenseBudgetRate}}%</text>
        </view>
      </view>

      <view class="summary-divider"></view>

      <view class="summary-item income-panel">
        <view class="summary-label">本月收入</view>
        <view class="summary-value income {{monthlyIncomeAmountSizeClass}}">+¥{{monthlyIncome}}</view>
        <view class="budget-track">
          <view class="budget-progress income-progress" style="width: {{incomeBudgetRate}}%;"></view>
        </view>
        <view class="budget-meta">
          <text>预算 ¥{{monthlyIncomeBudget}}</text>
          <text>{{incomeBudgetRate}}%</text>
        </view>
      </view>
    </view>

    <view class="balance-strip">
      <view>
        <view class="summary-label">本月结余</view>
        <view class="summary-value {{balance >= 0 ? 'income' : 'expense'}} {{balanceAmountSizeClass}} balance-value">{{balance >= 0 ? '+' : ''}}¥{{balance}}</view>
        <view class="balance-rate">本月结余率 {{balanceRate}}%</view>
      </view>
      <view class="daily-balance">
        <view class="summary-label">本月日均结余</view>
        <view class="daily-balance-value">¥{{averageDailyBalance}}</view>
      </view>
    </view>
  </view>

  <view class="quick-action-grid">
    <view class="quick-action-item" bindtap="goToAddRecord">
      <view class="quick-action-icon note-icon">记</view>
      <view class="quick-action-label">记一笔</view>
    </view>
    <view class="quick-action-item" bindtap="goToStatistics">
      <view class="quick-action-icon report-icon">报</view>
      <view class="quick-action-label">报表</view>
    </view>
    <view class="quick-action-item" bindtap="goToStatistics">
      <view class="quick-action-icon budget-icon">算</view>
      <view class="quick-action-label">预算</view>
    </view>
    <view class="quick-action-item" bindtap="goToAccounts">
      <view class="quick-action-icon account-icon">户</view>
      <view class="quick-action-label">账户</view>
    </view>
  </view>

  <view class="recent-card card">
    <view class="section-header flex flex-between">
      <view class="section-title">最近交易</view>
      <view class="section-more">全部 ›</view>
    </view>

    <view wx:if="{{groupedRecords.length === 0}}" class="empty-state">
      <view class="empty-icon">TXN</view>
      <view class="empty-text">还没有记账记录哦</view>
      <view class="empty-hint">点击下方按钮开始记账吧～</view>
    </view>
    
    <view wx:for="{{groupedRecords}}" wx:key="dateKey" class="date-group">
      <view class="date-header {{item.isCollapsed ? 'collapsed' : ''}}" bindtap="toggleDateGroup" data-date-key="{{item.dateKey}}">
        <view class="date-title">
          <view class="date-text">{{item.dateText}}</view>
          <view class="date-toggle-icon">{{item.isCollapsed ? '⌄' : '⌃'}}</view>
        </view>
        <view class="date-summary">
          <text wx:if="{{item.dayExpense > 0}}" class="date-expense">支出 ¥{{item.dayExpense}}</text>
          <text wx:if="{{item.dayIncome > 0}}" class="date-income">收入 ¥{{item.dayIncome}}</text>
        </view>
      </view>
      
      <block wx:if="{{!item.isCollapsed}}">
        <view wx:for="{{item.records}}" wx:for-item="record" wx:for-index="recordIndex" wx:key="id" class="record-card" bindtap="showRecordActions" data-record="{{record}}">
          <view class="record-left">
            <view class="category-icon badge-mark {{record.categoryBadge.className}}" style="background: {{record.categoryBadge.background}}; border-color: {{record.categoryBadge.color}}; color: {{record.categoryBadge.color}};">
              <image wx:if="{{record.categoryBadge.iconImage}}" class="badge-image" src="{{record.categoryBadge.iconImage}}" mode="aspectFit"></image>
              <block wx:else>
                <text class="badge-glyph">{{record.categoryBadge.symbol}}</text>
                <text class="badge-mark-text">{{record.categoryBadge.label}}</text>
              </block>
            </view>
            <view class="record-info">
              <view class="record-category" wx:if="{{record.type !== 'transfer'}}">{{record.category.name}}</view>
              <view class="record-category" wx:else>{{record.fromAccountDisplayName}} → {{record.toAccountDisplayName}}</view>
              <view class="record-note" wx:if="{{record.note}}">{{record.note}}</view>
              <view class="record-account" wx:if="{{record.accountDisplayName && record.type !== 'transfer'}}">{{record.accountDisplayName}}</view>
            </view>
          </view>
          <view class="record-right">
            <view class="record-amount {{record.type === 'expense' ? 'expense' : record.type === 'income' ? 'income' : 'transfer'}} {{record.amountSizeClass}}">
              <block wx:if="{{record.type === 'transfer'}}">¥{{record.amount}}</block>
              <block wx:else>{{record.type === 'expense' ? '-' : '+'}}¥{{record.amount}}</block>
            </view>
            <view class="record-more">•••</view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 操作弹窗 -->
  <view class="action-mask {{showActionSheet ? 'show' : ''}}" bindtap="hideActionSheet">
    <view class="action-sheet" catchtap="">
      <view class="action-sheet-header">
        <text class="action-sheet-title">操作记录</text>
        <text class="action-sheet-close" bindtap="hideActionSheet">✕</text>
      </view>
      <view class="action-list">
        <view class="action-item" bindtap="editRecord">
          <text class="action-icon">ED</text>
          <text class="action-text">编辑记录</text>
        </view>
        <view class="action-item delete" bindtap="deleteRecord">
          <text class="action-icon">DEL</text>
          <text class="action-text">删除记录</text>
        </view>
      </view>
    </view>
  </view>

</view>
