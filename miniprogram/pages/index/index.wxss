.page-container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.summary-card {
  margin-bottom: 30rpx;
}

.summary-header {
  align-items: center;
}

.summary-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.summary-month {
  font-size: 28rpx;
  color: #999;
}

.summary-data {
  align-items: center;
}

.summary-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
}

.summary-value.expense {
  color: #2ECC71;
}

.summary-value.income {
  color: #E74C3C;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: #FFE8E8;
}

.section-header {
  align-items: center;
  margin: 30rpx 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.date-group {
  margin-bottom: 30rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 10rpx 20rpx;
}

.date-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.date-summary {
  font-size: 24rpx;
}

.date-expense {
  color: #2ECC71;
  margin-left: 20rpx;
}

.date-income {
  color: #E74C3C;
  margin-left: 20rpx;
}

.record-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
}

.record-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-category {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-note {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-right {
  width: 220rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-amount {
  width: 100%;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.15;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
}

.amount-size-sm {
  font-size: 32rpx;
}

.amount-size-xs {
  font-size: 28rpx;
}

.record-amount.expense {
  color: #2ECC71;
}

.record-amount.income {
  color: #E74C3C;
}

.record-amount.transfer {
  color: #E74C3C;
}

.record-account {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.floating-btn-group {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 100;
}

.floating-btn {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
}

.floating-btn.transfer-btn {
  background: linear-gradient(135deg, #4ECDC4 0%, #6EE7DE 100%);
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.4);
}

.floating-icon {
  font-size: 60rpx;
  color: white;
  font-weight: 300;
  line-height: 1;
}

.record-more {
  width: 72rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
  line-height: 1;
  margin-top: 8rpx;
  margin-left: 0;
}

.action-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.action-mask.show {
  opacity: 1;
  visibility: visible;
}

.action-sheet {
  width: 100%;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: 40rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.action-mask.show .action-sheet {
  transform: translateY(0);
}

.action-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.action-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.action-sheet-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.action-list {
  padding: 20rpx 0;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  transition: background 0.2s;
}

.action-item:active {
  background: #f5f5f5;
}

.action-item.delete {
  color: #FF6B6B;
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-text {
  font-size: 30rpx;
  font-weight: 500;
}

/* Dark fintech dashboard overrides */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at 16% 0%, rgba(34, 211, 238, 0.14), transparent 34%),
    radial-gradient(circle at 88% 10%, rgba(20, 184, 166, 0.12), transparent 30%),
    linear-gradient(180deg, #07101D 0%, #070B14 100%);
}

.summary-card {
  padding: 28rpx;
  border-radius: 18rpx;
}

.summary-title,
.section-title {
  color: #E5EEF8;
  letter-spacing: 0;
}

.summary-month,
.summary-label,
.date-text,
.record-note,
.record-account,
.empty-hint {
  color: #8EA0B8;
}

.summary-divider {
  background: rgba(148, 163, 184, 0.16);
}

.summary-value.expense,
.date-expense,
.record-amount.expense {
  color: #22C55E;
}

.summary-value.income,
.date-income,
.record-amount.income,
.record-amount.transfer {
  color: #EF4444;
}

.record-card {
  background: rgba(15, 23, 42, 0.78);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: 16rpx;
  box-shadow: none;
}

.category-icon {
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 18rpx;
  box-shadow: inset 0 0 20rpx rgba(255, 255, 255, 0.04);
}

.category-icon .badge-glyph {
  font-size: 30rpx;
  font-weight: 800;
}

.record-category {
  color: #E5EEF8;
}

.record-more {
  color: #67E8F9;
}

.empty-text {
  color: #CBD5E1;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin: 0 auto 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(34, 211, 238, 0.28);
  background: rgba(34, 211, 238, 0.10);
  color: #67E8F9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.action-mask {
  background: rgba(2, 6, 23, 0.72);
}

.action-sheet {
  background: #0B1020;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.action-sheet-header {
  border-bottom-color: rgba(148, 163, 184, 0.14);
}

.action-sheet-title,
.action-text {
  color: #E5EEF8;
}

.action-sheet-close {
  color: #8EA0B8;
}

.action-icon {
  min-width: 58rpx;
  color: #67E8F9;
  font-size: 24rpx;
  font-weight: 800;
}

.action-item:active {
  background: rgba(34, 211, 238, 0.08);
}

.action-item.delete .action-text,
.action-item.delete .action-icon {
  color: #F87171;
}

.floating-btn {
  background: linear-gradient(135deg, #22D3EE 0%, #14B8A6 100%);
  box-shadow: 0 16rpx 34rpx rgba(34, 211, 238, 0.28);
}

.floating-btn.transfer-btn {
  background: linear-gradient(135deg, #2563EB 0%, #22D3EE 100%);
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.25);
}

.month-dashboard-card {
  margin-bottom: 18rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: rgba(15, 23, 42, 0.84);
}

.summary-month-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #E5EEF8;
  font-size: 30rpx;
  font-weight: 800;
}

.selector-arrow {
  color: #9AA8BA;
  font-size: 24rpx;
}

.calendar-mark {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #C8D3DF;
  border-radius: 8rpx;
  color: transparent;
  position: relative;
}

.calendar-mark::before,
.calendar-mark::after {
  content: '';
  position: absolute;
  top: 8rpx;
  width: 6rpx;
  height: 10rpx;
  border-radius: 4rpx;
  background: #C8D3DF;
}

.calendar-mark::before {
  left: 10rpx;
}

.calendar-mark::after {
  right: 10rpx;
}

.summary-data {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 1rpx minmax(0, 1fr);
  align-items: stretch;
  gap: 28rpx;
  padding: 24rpx 0 28rpx;
}

.summary-item {
  min-width: 0;
  text-align: left;
}

.summary-label {
  font-size: 24rpx;
  color: #8EA0B8;
  margin-bottom: 10rpx;
}

.summary-value {
  font-size: 38rpx;
  line-height: 1.12;
}

.summary-value.expense,
.date-expense,
.record-amount.expense {
  color: #FF6268;
}

.summary-value.income,
.date-income,
.record-amount.income {
  color: #18CDAA;
}

.record-amount.transfer {
  color: #22D3EE;
}

.budget-track {
  height: 10rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.16);
  overflow: hidden;
}

.budget-progress {
  height: 100%;
  border-radius: 999rpx;
}

.expense-progress {
  background: linear-gradient(90deg, #FF6268, #FF7B81);
}

.income-progress {
  background: linear-gradient(90deg, #18CDAA, #22D3B6);
}

.budget-meta {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #8EA0B8;
  font-size: 24rpx;
  white-space: nowrap;
}

.balance-strip {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.13);
}

.balance-value {
  color: #E5EEF8;
}

.balance-rate {
  margin-top: 8rpx;
  color: #AEB8C7;
  font-size: 24rpx;
}

.daily-balance {
  min-width: 190rpx;
  text-align: right;
}

.daily-balance-value {
  color: #AEB8C7;
  font-size: 30rpx;
  font-weight: 700;
}

.quick-action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 18rpx;
  padding: 22rpx 20rpx;
  background: rgba(15, 23, 42, 0.82);
  border-radius: 16rpx;
}

.quick-action-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.quick-action-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #06111F;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(2, 6, 23, 0.18);
}

.note-icon,
.report-icon,
.budget-icon {
  background: linear-gradient(135deg, #2DD4BF 0%, #22D3EE 100%);
}

.account-icon {
  background: linear-gradient(135deg, #0284C7 0%, #38BDF8 100%);
}

.quick-action-label {
  color: #D6E0EA;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1.2;
}

.recent-card {
  padding: 22rpx;
  background: rgba(15, 23, 42, 0.84);
  border-radius: 16rpx;
}

.section-header {
  margin: 0 0 12rpx;
}

.section-more {
  color: #8EA0B8;
  font-size: 24rpx;
}

.date-group {
  margin-bottom: 8rpx;
}

.date-header {
  padding: 14rpx 2rpx 12rpx;
}

.record-card {
  padding: 18rpx 0;
  margin-bottom: 0;
  border-radius: 0;
  border: 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.10);
  background: transparent;
}

.record-card:last-child {
  border-bottom: 0;
}

.record-category {
  font-size: 28rpx;
  font-weight: 750;
}

.record-account,
.record-note {
  color: #8EA0B8;
  font-size: 23rpx;
}

.summary-month-picker {
  display: block;
}

.date-header {
  border-radius: 10rpx;
}

.date-header:active {
  background: rgba(34, 211, 238, 0.08);
}

.date-title {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.date-toggle-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #67E8F9;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.date-header.collapsed {
  margin-bottom: 8rpx;
}
